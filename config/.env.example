# =============================================================================
# AI Newsletter Environment Configuration
# =============================================================================
# All variables use the NEWSLETTER_ prefix when loaded by the application.
# Copy this file to config/.env and fill in your values.
#
# Nested config values use double underscores:
#   NEWSLETTER_{SECTION}__{FIELD}  (e.g., NEWSLETTER_LLM__PROVIDER=anthropic)
# =============================================================================

# -- Application Secrets ------------------------------------------------------

# Secret key for signing sessions and tokens. REQUIRED for production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# If not set, a random key is generated on each restart (sessions will be lost).
NEWSLETTER_SECRET_KEY=change-me-to-a-random-string

# Public base URL for production (used in email links and redirects).
# Leave empty for local development (defaults to http://localhost:8000).
NEWSLETTER_BASE_URL=

# -- LLM Providers (set the key for your chosen provider) --------------------

# Anthropic API key (required if llm.provider is "anthropic" in config.yaml)
NEWSLETTER_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (required if llm.provider is "openai" in config.yaml)
NEWSLETTER_OPENAI_API_KEY=sk-...

# -- Data Source API Keys -----------------------------------------------------

# Twitter/X API v2 bearer token (required for Twitter fetcher)
NEWSLETTER_TWITTER_BEARER_TOKEN=

# Reddit API credentials (required for Reddit fetcher)
NEWSLETTER_REDDIT_CLIENT_ID=
NEWSLETTER_REDDIT_CLIENT_SECRET=
NEWSLETTER_REDDIT_USER_AGENT=ai-newsletter/1.0

# -- Email Delivery -----------------------------------------------------------

# Resend API key (required if email.provider is "resend" in config.yaml)
NEWSLETTER_RESEND_API_KEY=re_...

# SMTP password for Gmail or other SMTP providers.
# For Gmail, use an App Password: https://myaccount.google.com/apppasswords
# Note the double underscore — this sets email.smtp_password in config.
NEWSLETTER_EMAIL__SMTP_PASSWORD=your-smtp-app-password
